# =============================================================================
# OneClick.ai — Agent Runtime Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ---- REQUIRED ----
# Your OpenRouter API key. Get one free at https://openrouter.ai
# No credit card needed. Gives access to 28 free LLM models.
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE

# ---- AGENT CONFIGURATION ----
# The LLM model to use. "openrouter/auto" auto-routes to best available model.
# Other options: openrouter/meta-llama/llama-3.3-70b-instruct,
#   openrouter/google/gemma-3-27b-it, openrouter/qwen/qwen3-next-80b
AGENT_MODEL=openrouter/auto

# Display name for the agent
AGENT_NAME=Assistant

# System prompt — defines the agent's identity and behavior.
# For multi-line prompts, use \n for newlines.
AGENT_SYSTEM_PROMPT=You are a helpful AI assistant. You are friendly, professional, and concise. Help the user with whatever they need.

# ---- OPTIONAL: MESSAGING CHANNELS ----
# Uncomment and fill in to connect messaging channels.
# The agent will respond on all connected channels.

# Telegram Bot Token (get from @BotFather on Telegram)
# TELEGRAM_BOT_TOKEN=

# Slack Bot Token (from Slack app OAuth)
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

# Discord Bot Token
# DISCORD_BOT_TOKEN=

# WhatsApp Business API credentials
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=

# Email (IMAP/SMTP) for email-based interaction
# EMAIL_IMAP_HOST=
# EMAIL_IMAP_PORT=993
# EMAIL_IMAP_USER=
# EMAIL_IMAP_PASS=
# EMAIL_SMTP_HOST=
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=
# EMAIL_SMTP_PASS=

# ---- ADVANCED ----
# Timezone for the agent
TZ=Asia/Kolkata

# Memory limit for the container (OpenClaw gateway needs ~500MB)
AGENT_MEMORY_LIMIT=2048m

# Port to expose the gateway on (default 3000)
AGENT_PORT=3000

# Gateway auth token (auto-generated if not set)
# OPENCLAW_GATEWAY_TOKEN=
