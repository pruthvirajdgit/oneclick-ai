# === OneClick.ai Configuration ===

# LLM Providers (required)
GROQ_API_KEY=gsk_your_groq_api_key_here
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here

# Database
DATABASE_URL=postgres://oneclick:change-me-in-production@localhost:5432/oneclick
POSTGRES_USER=oneclick
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=oneclick
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# Auth
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRY_HOURS=24

# Internal Security (agent↔backend shared secret — MUST be a strong random value)
INTERNAL_SECRET=change-me-to-a-random-64-char-string

# CORS (comma-separated origins, or "*" for dev)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Agent Configuration
AGENT_IMAGE=oneclick-agent:latest
AGENT_MEMORY_LIMIT=4g
AGENT_CPU_LIMIT=0.5
MAX_AGENTS=100

# Rate Limiting
FREE_TIER_DAILY_LIMIT=50

# Idle Monitor
IDLE_TIMEOUT_MINUTES=15

# Logging
RUST_LOG=oneclick_backend=debug,tower_http=debug

# Production only
# DOMAIN=api.oneclick.ai
# ACME_EMAIL=admin@oneclick.ai
